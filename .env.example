# Upstash Redis. When you connect Upstash to the Vercel project these are
# injected automatically. The app accepts either naming scheme:
#   - Upstash integration:  UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   - older Vercel KV:       KV_REST_API_URL / KV_REST_API_TOKEN
# Copy the values here (as .env.local) only for local testing against the DB.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
